{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stealthpay.link/schemas/payment-profile.schema.json",
  "title": "StealthPay Payment Profile",
  "description": "Machine-readable schema for a StealthPay payment profile stored in ENS text records (stealthpay.v1.* namespace).",
  "type": "object",
  "required": ["ensName"],
  "properties": {
    "ensName": {
      "type": "string",
      "description": "Normalized ENS name",
      "pattern": "^[a-z0-9.-]+\\.eth$"
    },
    "address": {
      "type": ["string", "null"],
      "description": "Resolved Ethereum address",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "avatar": {
      "type": ["string", "null"],
      "description": "Avatar URI (ENS text record)"
    },
    "description": {
      "type": ["string", "null"],
      "description": "Profile description (ENS text record)"
    },
    "preferredChains": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^eip155:\\d+$",
        "description": "CAIP-2 chain identifier"
      },
      "description": "Preferred chains in CAIP-2 format"
    },
    "preferredAssets": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "CAIP-19 asset identifier"
      },
      "description": "Preferred assets in CAIP-19 format"
    },
    "preferredChain": {
      "type": ["string", "null"],
      "description": "Legacy-compatible friendly chain name (e.g. 'base')"
    },
    "preferredToken": {
      "type": ["string", "null"],
      "description": "Legacy-compatible token symbol (e.g. 'USDC')"
    },
    "stealthMetaAddress": {
      "type": ["string", "null"],
      "description": "ERC-5564 stealth meta-address (0x-prefixed hex: spendPub ++ viewPub)"
    },
    "stealthPolicy": {
      "type": "string",
      "enum": ["required", "preferred", "optional", "disabled"],
      "default": "preferred",
      "description": "Stealth payment policy. 'required' = reject transparent, 'preferred' = default to stealth, 'optional' = sender chooses, 'disabled' = no stealth"
    },
    "stealthSchemeIds": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      },
      "default": [1],
      "description": "Supported ERC-5564 scheme IDs (1 = secp256k1)"
    },
    "notePolicy": {
      "type": "string",
      "enum": ["required", "optional", "none"],
      "default": "optional",
      "description": "Note/memo policy. 'required' = sender must include, 'optional' = sender may include, 'none' = notes rejected"
    },
    "noteMaxBytes": {
      "type": "integer",
      "minimum": 0,
      "default": 140,
      "description": "Maximum memo length in bytes"
    },
    "notePrivacy": {
      "type": "string",
      "enum": ["plaintext", "encrypted", "hash_only"],
      "default": "plaintext",
      "description": "Note privacy mode. 'plaintext' = visible on-chain, 'encrypted' = ECDH-encrypted with viewing key, 'hash_only' = only keccak256 hash stored"
    }
  },
  "additionalProperties": false
}
